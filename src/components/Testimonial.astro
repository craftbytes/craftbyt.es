---
export interface Props {
  class?: string;
  children?: any;
  client?: { name: string; logo: string };
}

const { class: className, children, client } = Astro.props;
const cls = className || '';
---

<div class:list={[cls, 'relative isolate bg-neutral-50 py-16 sm:py-28 md:py-32']}>
  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 -z-10 h-full w-full mask-[linear-gradient(to_bottom_left,white_50%,transparent_60%)] fill-neutral-100 stroke-neutral-950/5" aria-hidden="true">
    <svg class="h-full w-full" aria-hidden="true">
      <defs>
        <pattern id="testimonial-grid" width="96" height="480" patternUnits="userSpaceOnUse" fill="none">
          <path d="M128 0 98.572 147.138A16 16 0 0 1 82.883 160H13.117a16 16 0 0 0-15.69 12.862l-26.855 134.276A16 16 0 0 1-45.117 320H-116M64-160 34.572-12.862A16 16 0 0 1 18.883 0h-69.766a16 16 0 0 0-15.69 12.862l-26.855 134.276A16 16 0 0 1-109.117 160H-180M192 160l-29.428 147.138A15.999 15.999 0 0 1 146.883 320H77.117a16 16 0 0 0-15.69 12.862L34.573 467.138A16 16 0 0 1 18.883 480H-52" stroke="#e5e7eb" fill="none"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#testimonial-grid)" />
    </svg>
  </div>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="fade-in" data-observe>
        <figure class="mx-auto max-w-4xl">
          <blockquote class="relative font-display text-3xl font-medium tracking-tight text-neutral-950 sm:text-4xl">
            <p class="before:content-['\201C'] after:content-['\201D'] sm:before:absolute sm:before:right-full">
              <slot />
            </p>
          </blockquote>
          {client && (
            <figcaption class="mt-10">
              <img src={client.logo} alt={client.name} class="h-16 w-16" />
            </figcaption>
          )}
        </figure>
      </div>
    </div>
  </div>
</div>
