---
export interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const cls = className || '';
---

<div class:list={[cls, 'mt-24 rounded-4xl bg-surface-2 py-20 sm:mt-32 sm:py-32 lg:mt-56']}>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:max-w-none">
      <div class="fade-in flex items-center gap-x-8" data-observe>
        <h2 class="text-center font-display text-sm font-semibold tracking-wider text-white sm:text-left">
          Trusted by teams building the future
        </h2>
        <div class="h-px flex-auto bg-neutral-800" />
      </div>
      <div class="fade-in-stagger mt-10 grid grid-cols-2 gap-x-8 gap-y-10 lg:grid-cols-4" data-observe-stagger>
        <div class="fade-in" data-observe><img src="/images/clients/client-1.svg" alt="Client" class="h-8 opacity-40 grayscale" /></div>
        <div class="fade-in" data-observe><img src="/images/clients/client-2.svg" alt="Client" class="h-8 opacity-40 grayscale" /></div>
        <div class="fade-in" data-observe><img src="/images/clients/client-3.svg" alt="Client" class="h-8 opacity-40 grayscale" /></div>
        <div class="fade-in" data-observe><img src="/images/clients/client-4.svg" alt="Client" class="h-8 opacity-40 grayscale" /></div>
      </div>
    </div>
  </div>
</div>
