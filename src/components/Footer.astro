---
export interface Props {
  class?: string;
  children?: any;
}

const { class: className, children } = Astro.props;
const cls = className || '';
---

<footer class:list={['mx-auto max-w-7xl px-6 lg:px-8 mt-24 w-full sm:mt-32 lg:mt-40', cls]}>
  <div class="mx-auto max-w-2xl lg:max-w-none">
    <div class="fade-in" data-observe>
      <div class="grid grid-cols-1 gap-x-8 gap-y-16 lg:grid-cols-2">
        <nav>
          <ul role="list" class="grid grid-cols-2 gap-8 sm:grid-cols-3">
            <li>
              <div class="font-display text-sm font-semibold tracking-wider text-neutral-950">Services</div>
              <ul role="list" class="mt-4 text-sm text-neutral-700">
                <li class="mt-4"><a href="#services" class="transition hover:text-neutral-950">Fractional CTO</a></li>
                <li class="mt-4"><a href="#services" class="transition hover:text-neutral-950">Backend Architecture</a></li>
                <li class="mt-4"><a href="#services" class="transition hover:text-neutral-950">Rails Modernization &amp; Upgrades</a></li>
                <li class="mt-4"><a href="#services" class="transition hover:text-neutral-950">Platform &amp; Infrastructure</a></li>
              </ul>
            </li>
            <li>
              <div class="font-display text-sm font-semibold tracking-wider text-neutral-950">Company</div>
              <ul role="list" class="mt-4 text-sm text-neutral-700">
                <li class="mt-4"><a href="mailto:hello@craftbyt.es" class="transition hover:text-neutral-950">Contact</a></li>
              </ul>
            </li>
            <li>
              <div class="font-display text-sm font-semibold tracking-wider text-neutral-950">Connect</div>
              <ul role="list" class="mt-4 text-sm text-neutral-700">
                <li class="mt-4"><a href="https://github.com/ramulifho" target="_blank" class="transition hover:text-neutral-950">GitHub</a></li>
                <li class="mt-4"><a href="https://linkedin.com/in/diraulo" target="_blank" class="transition hover:text-neutral-950">LinkedIn</a></li>
              </ul>
            </li>
          </ul>
        </nav>
        <div class="flex lg:justify-end">
          <div class="max-w-sm">
            <h2 class="font-display text-sm font-semibold tracking-wider text-neutral-950">Get in touch</h2>
            <p class="mt-4 text-sm text-neutral-700">
              Not sure if this is the right fit? Send an email anyway. Worst case, I'll point you somewhere useful.
            </p>
            <div class="relative mt-6">
              <a
                href="mailto:hello@craftbyt.es"
                class="inline-flex rounded-full bg-neutral-950 px-6 py-3 text-sm font-semibold text-white transition hover:bg-neutral-800"
              >
                hello@craftbyt.es
              </a>
            </div>
          </div>
        </div>
      </div>
      <div class="mt-24 mb-20 flex flex-wrap items-end justify-between gap-x-6 gap-y-4 border-t border-neutral-950/10 pt-12">
        <a href="/" aria-label="Home">
          <img src="/cb-logo-type.svg" alt="Craftbytes" class="h-8" />
        </a>
        <p class="text-sm text-neutral-700">
          &copy; Craftbytes Inc. {new Date().getFullYear()}
        </p>
      </div>
    </div>
  </div>
</footer>
