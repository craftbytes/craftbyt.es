---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-lg bg-[#0b0d11]/80 border-b border-border">
    <div class="max-w-[1000px] mx-auto px-6 h-[60px] flex items-center justify-between">
      <a href="#" class="font-bold text-lg">
        <span class="bg-gradient-to-r from-accent to-purple-400 bg-clip-text text-transparent">Craftbytes</span><span class="text-text-dim font-normal">.</span>
      </a>
      <nav class="flex items-center gap-8">
        <a href="#services" class="text-text-dim text-sm font-medium hover:text-text transition-colors">Services</a>
        <a href="#about" class="text-text-dim text-sm font-medium hover:text-text transition-colors">About</a>
        <a href="#contact" class="bg-accent text-white px-4 py-1.5 rounded-md text-xs font-semibold hover:bg-accent-dim transition-colors">Get in touch</a>
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="pt-32 pb-16 relative overflow-hidden">
    <div class="absolute top-[-20%] right-[-10%] w-[600px] h-[600px] bg-[radial-gradient(circle,rgba(108,140,255,0.08)_0%,transparent_70%)] pointer-events-none"></div>
    <div class="max-w-[1000px] mx-auto px-6 relative">
      <div class="flex gap-2 flex-wrap mb-6">
        <span class="inline-flex items-center gap-1.5 bg-surface-2 border border-border px-3 py-1.5 rounded-md text-xs text-text-dim">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400"></span> Available for engagements
        </span>
        <span class="inline-flex items-center gap-1.5 bg-surface-2 border border-border px-3 py-1.5 rounded-md text-xs text-text-dim">
          <span class="w-1.5 h-1.5 rounded-full bg-accent"></span> Ontario, Canada
        </span>
        <span class="inline-flex items-center gap-1.5 bg-surface-2 border border-border px-3 py-1.5 rounded-md text-xs text-text-dim">
          <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span> Remote-first
        </span>
      </div>
      <h1 class="text-[clamp(2.2rem,5vw,3.5rem)] font-semibold leading-tight -tracking-[0.02em] mb-5">
        Software consulting &<br>
        <span class="bg-gradient-to-r from-accent to-purple-400 bg-clip-text text-transparent">fractional technical leadership</span>
      </h1>
      <p class="text-lg text-text-dim max-w-[650px] mb-8 leading-relaxed">
        I help growing teams ship better software — architecture, platform engineering,
        and hands-on technical direction. Based in Canada, working globally.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a href="#contact" class="inline-flex items-center gap-2 bg-accent text-white px-6 py-3 rounded-lg text-sm font-semibold hover:bg-accent-dim transition-all hover:-translate-y-0.5">
          Work with me →
        </a>
        <a href="#services" class="inline-flex items-center gap-2 bg-surface-2 text-text border border-border px-6 py-3 rounded-lg text-sm font-semibold hover:bg-border transition-all">
          View services
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="py-16">
    <div class="max-w-[1000px] mx-auto px-6">
      <h2 class="text-[clamp(1.5rem,3vw,2rem)] font-semibold -tracking-[0.01em] mb-2">Services</h2>
      <p class="text-text-dim mb-12 max-w-[600px]">
        Flexible engagement — from a strategic advisory call to embedded, ongoing technical leadership.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <!-- Fractional CTO -->
        <div class="bg-surface border border-border rounded-xl p-7 hover:border-accent transition-all hover:-translate-y-0.5">
          <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4 text-xl">⚡</div>
          <h3 class="text-lg font-semibold mb-2">Fractional CTO</h3>
          <p class="text-text-dim text-sm mb-3">Technical leadership for teams that don't need (or can't afford) a full-time CTO yet.</p>
          <ul class="space-y-1 text-text-dim text-xs">
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Technical strategy & roadmap</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Team mentoring & hiring</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Architecture decisions & reviews</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">5–20 hours/week, flexible</li>
          </ul>
        </div>

        <!-- Backend Architecture -->
        <div class="bg-surface border border-border rounded-xl p-7 hover:border-accent transition-all hover:-translate-y-0.5">
          <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4 text-xl">🛠️</div>
          <h3 class="text-lg font-semibold mb-2">Backend Architecture</h3>
          <p class="text-text-dim text-sm mb-3">Design and build the systems that scale with your product — not against it.</p>
          <ul class="space-y-1 text-text-dim text-xs">
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Elixir & Phoenix applications</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">API design & real-time systems</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Data pipelines & event-driven architecture</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Performance optimisation</li>
          </ul>
        </div>

        <!-- Platform & Infrastructure -->
        <div class="bg-surface border border-border rounded-xl p-7 hover:border-accent transition-all hover:-translate-y-0.5">
          <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4 text-xl">☁️</div>
          <h3 class="text-lg font-semibold mb-2">Platform & Infrastructure</h3>
          <p class="text-text-dim text-sm mb-3">Infrastructure that your team can actually ship on. Kubernetes, GitOps, and deployment pipelines.</p>
          <ul class="space-y-1 text-text-dim text-xs">
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Kubernetes architecture & operations</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">GitOps workflows (ArgoCD / Flux)</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">CI/CD pipeline design</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Observability & incident response</li>
          </ul>
        </div>

        <!-- Technical Due Diligence -->
        <div class="bg-surface border border-border rounded-xl p-7 hover:border-accent transition-all hover:-translate-y-0.5">
          <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center mb-4 text-xl">🔍</div>
          <h3 class="text-lg font-semibold mb-2">Technical Due Diligence</h3>
          <p class="text-text-dim text-sm mb-3">An independent look at your codebase, architecture, and engineering practices.</p>
          <ul class="space-y-1 text-text-dim text-xs">
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Codebase & architecture audit</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Technical debt assessment</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Security & compliance review</li>
            <li class="pl-4 relative before:content-['→'] before:absolute before:left-0 before:text-accent">Actionable remediation roadmap</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- How I Work -->
  <section class="py-16">
    <div class="max-w-[1000px] mx-auto px-6">
      <h2 class="text-[clamp(1.5rem,3vw,2rem)] font-semibold -tracking-[0.01em] mb-2">How I work</h2>
      <p class="text-text-dim mb-12 max-w-[600px]">
        No time-sheets, no bureaucracy. Just clear outcomes and direct communication.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="bg-surface border border-border rounded-xl p-6 text-center">
          <div class="text-[2rem] font-bold bg-gradient-to-r from-accent to-purple-400 bg-clip-text text-transparent mb-2">01</div>
          <h3 class="font-semibold mb-2">Understand</h3>
          <p class="text-text-dim text-xs leading-relaxed">We talk through where you are, where you want to be, and what's in the way.</p>
        </div>
        <div class="bg-surface border border-border rounded-xl p-6 text-center">
          <div class="text-[2rem] font-bold bg-gradient-to-r from-accent to-purple-400 bg-clip-text text-transparent mb-2">02</div>
          <h3 class="font-semibold mb-2">Plan</h3>
          <p class="text-text-dim text-xs leading-relaxed">I lay out a concrete plan — scope, timeline, and expected outcomes — no surprises.</p>
        </div>
        <div class="bg-surface border border-border rounded-xl p-6 text-center">
          <div class="text-[2rem] font-bold bg-gradient-to-r from-accent to-purple-400 bg-clip-text text-transparent mb-2">03</div>
          <h3 class="font-semibold mb-2">Execute</h3>
          <p class="text-text-dim text-xs leading-relaxed">Hands-on delivery. Code, architecture, or leadership — whatever the situation needs.</p>
        </div>
        <div class="bg-surface border border-border rounded-xl p-6 text-center">
          <div class="text-[2rem] font-bold bg-gradient-to-r from-accent to-purple-400 bg-clip-text text-transparent mb-2">04</div>
          <h3 class="font-semibold mb-2">Evolve</h3>
          <p class="text-text-dim text-xs leading-relaxed">We iterate. I stay as long as I'm useful, and you're never locked into a contract.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-16">
    <div class="max-w-[1000px] mx-auto px-6">
      <h2 class="text-[clamp(1.5rem,3vw,2rem)] font-semibold -tracking-[0.01em] mb-2">About</h2>
      <p class="text-text-dim mb-12 max-w-[600px]">
        A backend engineer who's built and operated systems at scale.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
        <div>
          <p class="text-text-dim text-sm leading-relaxed mb-4">
            I'm <strong class="text-text font-semibold">Raoul</strong>, a backend engineer based in Ontario, Canada.
            I specialise in <strong class="text-text font-semibold">Elixir & Phoenix</strong>, distributed systems,
            and platform engineering with Kubernetes and GitOps.
          </p>
          <p class="text-text-dim text-sm leading-relaxed mb-4">
            Over the years I've designed APIs, built real-time systems, operated
            production infrastructure, and led engineering teams — both as a full-time
            engineer and as a fractional technical lead.
          </p>
          <p class="text-text-dim text-sm leading-relaxed mb-6">
            I work remotely with teams across North America and Europe. Every engagement
            is hands-on: I don't just advise, I build.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-surface-2 border border-border px-2.5 py-1 rounded-md text-[0.8rem] text-text-dim font-mono">Elixir</span>
            <span class="bg-surface-2 border border-border px-2.5 py-1 rounded-md text-[0.8rem] text-text-dim font-mono">Phoenix</span>
            <span class="bg-surface-2 border border-border px-2.5 py-1 rounded-md text-[0.8rem] text-text-dim font-mono">Erlang/OTP</span>
            <span class="bg-surface-2 border border-border px-2.5 py-1 rounded-md text-[0.8rem] text-text-dim font-mono">Kubernetes</span>
            <span class="bg-surface-2 border border-border px-2.5 py-1 rounded-md text-[0.8rem] text-text-dim font-mono">ArgoCD</span>
            <span class="bg-surface-2 border border-border px-2.5 py-1 rounded-md text-[0.8rem] text-text-dim font-mono">PostgreSQL</span>
            <span class="bg-surface-2 border border-border px-2.5 py-1 rounded-md text-[0.8rem] text-text-dim font-mono">AWS</span>
            <span class="bg-surface-2 border border-border px-2.5 py-1 rounded-md text-[0.8rem] text-text-dim font-mono">Terraform</span>
          </div>
        </div>
        <div class="bg-surface border border-border rounded-xl p-6">
          <h4 class="text-[0.8rem] uppercase tracking-wider text-text-muted mb-4 font-semibold">Engagement details</h4>
          <ul class="space-y-0">
            <li class="py-3 border-b border-border flex items-center gap-2 text-sm text-text-dim last:border-b-0">
              <span class="text-text-muted text-xs min-w-[80px]">Location</span>
              <span class="text-text">Ontario, Canada (EST/EDT)</span>
            </li>
            <li class="py-3 border-b border-border flex items-center gap-2 text-sm text-text-dim last:border-b-0">
              <span class="text-text-muted text-xs min-w-[80px]">Time zones</span>
              <span class="text-text">EST • GMT ±3 preferred</span>
            </li>
            <li class="py-3 border-b border-border flex items-center gap-2 text-sm text-text-dim last:border-b-0">
              <span class="text-text-muted text-xs min-w-[80px]">Start from</span>
              <span class="text-text">2 weeks (typical)</span>
            </li>
            <li class="py-3 border-b border-border flex items-center gap-2 text-sm text-text-dim last:border-b-0">
              <span class="text-text-muted text-xs min-w-[80px]">Minimum</span>
              <span class="text-text">8 hours/week</span>
            </li>
            <li class="py-3 border-b border-border flex items-center gap-2 text-sm text-text-dim last:border-b-0">
              <span class="text-text-muted text-xs min-w-[80px]">Billing</span>
              <span class="text-text">Weekly retainer or hourly</span>
            </li>
            <li class="py-3 border-b border-border flex items-center gap-2 text-sm text-text-dim last:border-b-0">
              <span class="text-text-muted text-xs min-w-[80px]">Rates</span>
              <span class="text-text">From $125 CAD/hour</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-16 border-t border-border">
    <div class="max-w-[1000px] mx-auto px-6">
      <div class="flex flex-wrap justify-between gap-8">
        <div>
          <h2 class="text-[clamp(1.5rem,3vw,2rem)] font-semibold -tracking-[0.01em] mb-2">Let's talk</h2>
          <p class="text-text-dim text-sm max-w-[400px] leading-relaxed">
            Whether you need a sounding board for an architecture decision or
            ongoing technical leadership — send me a message and I'll get back
            to you within a business day.
          </p>
        </div>
        <div class="flex flex-col gap-3">
          <a href="mailto:hello@craftbyt.es" class="flex items-center gap-3 text-text-dim text-sm bg-surface border border-border rounded-lg px-4 py-2.5 hover:text-text hover:border-accent transition-all">
            <span class="text-base min-w-[20px] text-center">✉</span>
            hello@craftbyt.es
          </a>
          <a href="https://www.linkedin.com" target="_blank" rel="noopener" class="flex items-center gap-3 text-text-dim text-sm bg-surface border border-border rounded-lg px-4 py-2.5 hover:text-text hover:border-accent transition-all">
            <span class="text-base min-w-[20px] text-center">🔗</span>
            LinkedIn
          </a>
          <a href="https://github.com/ramulifho" target="_blank" rel="noopener" class="flex items-center gap-3 text-text-dim text-sm bg-surface border border-border rounded-lg px-4 py-2.5 hover:text-text hover:border-accent transition-all">
            <span class="text-base min-w-[20px] text-center">⌨</span>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-8 border-t border-border text-center text-text-muted text-xs">
    <div class="max-w-[1000px] mx-auto px-6">
      <p>&copy; 2026 Craftbytes. All rights reserved.</p>
    </div>
  </footer>
</Layout>
