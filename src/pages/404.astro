---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Not found" description="Page not found">
  <section class="min-h-screen flex items-center justify-center bg-white">
    <div class="text-center">
      <h1 class="text-8xl font-display font-semibold text-neutral-200 mb-4">404</h1>
      <h2 class="text-2xl font-semibold text-neutral-950 mb-4">Page not found</h2>
      <p class="text-neutral-600 mb-8">The page you are looking for doesn't exist.</p>
      <a href="/" class="inline-flex rounded-full bg-neutral-950 text-white px-6 py-3 text-sm font-semibold hover:bg-neutral-800 transition">Go Home</a>
    </div>
  </section>
</Layout>
